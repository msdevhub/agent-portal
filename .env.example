# Agent Portal — Environment Variables
# Copy to .env and fill in actual values.
# Backend (server.cjs) and Pipeline (digest/) share the same env vars.

# ── Database (required) ──
DATABASE_URL=postgresql://agent_portal:CHANGE_ME@localhost:5432/postgres

# ── Mattermost (required) ──
MM_BASE_URL=https://mm.example.com
MM_ADMIN_TOKEN=your_mm_admin_token_here
MM_ADMIN_USER_ID=mattermost_admin_user_id

# ── LLM — Azure OpenAI (required for Pipeline) ──
L1_BASE_URL=https://your-resource.cognitiveservices.azure.com/openai/v1/
L1_API_KEY=your_azure_openai_key_here
L1_MODEL=gpt-4.1
L2_MODEL=gpt-5.4
L3_MODEL=gpt-5.4

# ── Optional ──
# PORT=3002                    # API server port (default: 3013)
# DADDY_USER_ID=mm_user_id     # Override @dora user ID
# MM_TEAM_ID=mm_team_id        # Override MM team ID
# DIGEST_DATA_DIR=/path/to/data # Override digest data directory
