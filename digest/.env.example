# --- Database (preferred: PG direct) ---
# Set DATABASE_URL for direct PostgreSQL connection (recommended)
# If not set, falls back to Supabase REST API
DATABASE_URL=postgresql://agent_portal:AgentP0rtal2026!@localhost:5432/postgres

# --- Supabase (fallback, only needed if DATABASE_URL is not set) ---
# SUPABASE_URL=https://db.dora.restry.cn/pg
# SUPABASE_SERVICE_KEY=     # Supabase service_role JWT

# --- Mattermost ---
MM_BASE_URL=https://mm.dora.restry.cn
MM_ADMIN_TOKEN=           # Required: Mattermost admin/bot token
DADDY_USER_ID=8zzs18ha4fdhf8jt8ybm61eqdw
MM_TEAM_ID=x1dtaayrof878chorb6mrj9ana

# --- LLM (Azure OpenAI) ---
L1_BASE_URL=https://resley-east-us-2-resource.cognitiveservices.azure.com/openai/v1/
L1_API_KEY=               # Required: Azure OpenAI API key
L1_MODEL=gpt-4.1          # L1 structured extraction model
L1_FALLBACK=gpt-4o        # Fallback model if L1 fails
